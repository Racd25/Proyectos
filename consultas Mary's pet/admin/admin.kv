                        text: 'Fecha del Examen:'
                        size_hint_x: 0.3
                        color: 1, 1, 1, 1
                    TextInput:
                        id: detalle_examen_fecha
                        size_hint_x: 0.7
                        text_size: self.size
                        halign: 'left'
						readonly: True
                        color: 1, 1, 1, 1


                #
                Label:
                    text: "EXAMENES DE LABORATORIO"
                    size_hint_y: None
                    height: dp(30)
                    bold: True
                    color: 1, 1, 1, 1

                GridLayout:
                    cols: 10
                    rows: 8
                    size_hint_y: None
                    height: 8 * 40  # 8 filas de 40dp de alto
                    spacing: 2, 2
                    padding: 0


                    # Fila 1
