                    TextInput:
                        id: detalle_vcm
                        readonly: True
                        background_color: (0.9, 0.9, 0.9, 1)
                    Label:
                        text: "Bun"
                        color: 1, 1, 1, 1
                    TextInput:
                        id: detalle_bun
                        readonly: True
                        background_color: (0.9, 0.9, 0.9, 1)
                    
                    Label:
