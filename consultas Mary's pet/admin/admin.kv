                    TextInput:
                        id: detalle_otras_40
                        readonly: True
                        background_color: (0.9, 0.9, 0.9, 1)


                   # Fila 5

                    Label:
                        text: ""
                        color: (0, 0, 0, 1)
                    Label:
                        text: "Neut"
                        color: 1, 1, 1, 1
                    TextInput:
                        id: detalle_neut
                        readonly: True
                        background_color: (0.9, 0.9, 0.9, 1)
                    Label:
                        text: "HCM"
                        color: 1, 1, 1, 1
                    TextInput:
                        id: detalle_hcm
                        readonly: True
                        background_color: (0.9, 0.9, 0.9, 1)
                    Label:
