                    Label:
                        text: ''
                        color: 1, 1, 1, 1
                        background_color: 0.2, 0.2, 0.2, 1
                    Label:
                        text: ''
                        color: 1, 1, 1, 1
                        background_color: 0.2, 0.2, 0.2, 1
                    Label:
